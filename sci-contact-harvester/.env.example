# GitHub personal access token used for repository API access.
GITHUB_TOKEN=

# GitHub repository name in the format "username/repo".
GITHUB_REPO_NAME=

# Git branch to read from or sync against.
GITHUB_BRANCH=

# SerpAPI key used for Google search requests.
SERPAPI_KEY=

# Anthropic API key used for Claude-powered enrichment.
ANTHROPIC_API_KEY=

# Path to the local SQLite database file.
DB_PATH=

# Delay in seconds between scrape requests.
SCRAPE_DELAY=
